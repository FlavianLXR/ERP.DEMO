                                    </div>
                                </div>
                                <div class="row mb-2 mb-sm-3">
                                    <div class="col">
                                        <MudTextField InputType="InputType.Number" @bind-Value="product.Volume" Label="Volume (cl)" Variant="Variant.Outlined" Placeholder="Volume en cl" For="@(() => product.Volume)" HideSpinButtons />
