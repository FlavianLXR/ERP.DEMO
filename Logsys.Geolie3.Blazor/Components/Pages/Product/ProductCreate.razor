                            </div>
                            <div class="col-2" style="justify-items: right;">
                                <MudSwitch @bind-Value="product.IsActiv" Color="Color.Success" Label="Actif" />
                            </div>
                        </div>
                        <div class="row mt-2">
                            <div class="col-sm-6">
                                @* <MudSelect @bind-Value="product.TypeId" Label="Type" Placeholder="Type d'article" Variant="Variant.Outlined" For="@(() => product.TypeId)" Dense>
                                    @if (productTypes != null)
                                    {
                                        @foreach (var type in productTypes)
                                        {
                                            <MudSelectItem Value="@type.Value">@type.Text</MudSelectItem>
                                        }
                                    }
                                </MudSelect> *@
                            </div>
                            <div class="col-sm-6">
                                <MudTextField @bind-Value="product.Description" Label="Code" Placeholder="Identifiant géolie de l'article" Variant="Variant.Outlined" For="@(() => product.Description)" />
                            </div>
                        </div>
                        <div class="row mt-2">
                            @* <div class="col-sm-6">
                                <MudTextField @bind-Value="product.CustomerReference" Label="Réf client" Placeholder="Identifiant client de l'article" Variant="Variant.Outlined" For="@(() => product.CustomerReference)" />
                            </div> *@
                            <div class="col-sm-6">
                                <MudTextField @bind-Value="product.Label" Label="Libellé" Placeholder="Nom de l'article" Variant="Variant.Outlined" For="@(() => product.Label)" />
                            </div>
                        </div>
                       @*  <div class="row mt-2">
                            <div class="col-sm-6">
                                <MudTextField @bind-Value="product.FstIndentifer" Label="Identifiant 1" Placeholder="Premier identifiant supplémentaire" Variant="Variant.Outlined" For="@(() => product.FstIndentifer)" />
                            </div>
                            <div class="col-sm-6">
                                <MudTextField @bind-Value="product.SndIdentifier" Label="identifiant 2" Placeholder="Second identifiant supplémentaire" Variant="Variant.Outlined" For="@(() => product.SndIdentifier)" />
                            </div>
                        </div>
                        <div class="row mt-2">
                            <div class="col">
                                <MudTextField @bind-Value="product.Description" Label="Description" Placeholder="Description" Lines="2" Variant="Variant.Outlined" For="@(() => product.Description)" />
                            </div>
                        </div>
                        <div class="row mt-2">
                            <div class="col">
                                <MudTextField @bind-Value="product.Comment" Label="Commentaire" Placeholder="Commentaire" Lines="2" Variant="Variant.Outlined" For="@(() => product.Comment)" />
                            </div>
                        </div>
                        <div class="row mt-2">
                            <div class="col">
                                <MudTextField @bind-Value="product.Constraint" Label="Contrainte" Placeholder="Contrainte" Lines="2" Variant="Variant.Outlined" For="@(() => product.Constraint)" />
                            </div>
