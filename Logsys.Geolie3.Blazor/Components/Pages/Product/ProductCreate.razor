@page "/product/create"
@using ERP.DEMO.ViewModels
@using static ERP.DEMO.ViewModels.ProductHelperViewModels
@inject IDialogService DialogService
@inject ProductService ProductService
@inject NavigationManager NavigationManager
@inject LoggerService Logger
@rendermode InteractiveServer

<div class="container-fluid pt-4">
    <div class="ms-3 me-3">
        <div class="row d-flex">
            <div class="col d-flex" style="justify-content: space-between;">
                <div>
                    <h3 class="mb-3 h4 font-weight-bolder">Nouvel article</h3>
                </div>
                <div>
                    <MudButton OnClick="Cancel" Variant="Variant.Outlined" Color="Color.Secondary" Class="me-2">
                        Annuler
                    </MudButton>
                    <MudButton OnClick="SubmitForm" Variant="Variant.Filled" Color="Color.Primary">
                        Enregistrer
                    </MudButton>
                </div>
            </div>
        </div>

        <EditForm EditContext="editContext">
            @if (validationErrors != null && validationErrors.Any())
            {
                <div class="row">
                    <div class="col">
                        <MudAlert Severity="Severity.Error" Class="align-center rounded border border-wide border-error text-center mb-2">
                            <MudText Color="Color.Error" Typo="Typo.body1">
                                <ul style="list-style-type: disc; padding-left: 1.5rem; text-align: left;">
                                    <span>Liste des erreurs</span>
                                    @foreach (var error in validationErrors)
                                    {
                                        <li>
                                            @error.Message
                                        </li>
                                    }
                                </ul>
                            </MudText>
                        </MudAlert>
                    </div>
                </div>
            }

            <DataAnnotationsValidator />
            <MudTabs Elevation="2" KeepPanelsAlive Rounded="true" Class="mt-4" Border="true" ApplyEffectsToContainer="true" Ripple="false">
