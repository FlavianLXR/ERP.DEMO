                            </div>
                        </div>
                        <h5 class="rounded-label pl-1 pb-1 mb-3 mt-3">Stocks & gammes</h5>
                        <div class="row mt-2">
                            <small class="text-info">
                                <span class="fa fa-lg fa-info-circle px-2"></span>
