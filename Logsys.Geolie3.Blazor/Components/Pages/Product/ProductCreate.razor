</div>

@code {
    [CascadingParameter] public MainLayout MainLayout { get; set; }
    private ProductCreateViewModel product = new();
    private EditContext editContext;
    // private List<BaseService.SelectItem<int>> productTypes;
    // private List<BaseService.SelectItem<string?>> productOperations;
    // private List<BaseService.SelectItem<int>> productFamilies;
    // private List<BaseService.SelectItem<int?>> productProvider;
    // private List<BaseService.SelectItem<string>> alcoholType;
    // private List<BaseService.SelectItem<string>> serialNumberAlgorithms;
    private IEnumerable<StockViewModel> stockViewmodel;
    private List<BaseService.ValidationError> validationErrors = new List<BaseService.ValidationError>();
    private ValidationMessageStore messageStore;

    protected override async Task OnInitializedAsync()
    {
        editContext = new EditContext(product);
        // alcoholType = ProductService.AlcoholType;
        // serialNumberAlgorithms = ProductService.Algorythms;
        // productTypes = ProductService.PopulateProductTypeDropDownList();
        // productOperations = ProductService.PopulateOperationDropDownList(true);
        // productFamilies = ProductService.PopulateFamilyDropDownList();
        // productProvider = ProductService.PopulateProviderDropDownList(true);
        // stockViewmodel = ProductService.PopulateStockAndRangeSelector();
        // if (product.TypeId == 0) product.TypeId = productTypes.FirstOrDefault().Value;
        // if (product.FamilyId == 0) product.FamilyId = productFamilies.FirstOrDefault().Value;
        messageStore = new ValidationMessageStore(editContext);
    }

    private async Task SubmitForm()
    {
        messageStore.Clear();
        var isValid = editContext.Validate();
        validationErrors = await ProductService.AddModelStateRulesAsync(
            product.ToProduct()
            // product.SelectedRanges,
            //  product.SelectedRangesByStock.Select(x => x.Value).ToList()
        );
        foreach (var error in editContext.GetValidationMessages())
        {
            validationErrors.Add(new BaseService.ValidationError() { Message = error });
        }

        foreach (var error in validationErrors)
        {
            if (!string.IsNullOrWhiteSpace(error.FieldName))
            {
                var accessor = new FieldIdentifier(product, error.FieldName); ;
                messageStore.Add(accessor, error.Message);
            }
            else
            {
                messageStore.Add(new FieldIdentifier(product, string.Empty), error.Message);
            }
        }

        if (validationErrors.Count() > 0 || !isValid)
        {
            editContext.NotifyValidationStateChanged();
            return;
        }

        var result = await ProductService.CreateProductAsync(product.ToProduct());
        // var result = await ProductService.CreateProductAsync(product.ToProduct(), product.SelectedRangesByStock.Select(x => x.Value).ToList());
        if (!result.Success)
        {
            MainLayout?.MudSnackbarService?.AddSnackbar("Une erreur est survenue lors de la modification de l'article", Severity.Error);
            return;
        }
        MainLayout?.MudSnackbarService?.AddSnackbar("L'article a été créé avec succès", Severity.Success);
        NavigationManager.NavigateTo($"product/details/{product.Id}");
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("product");
    }

    // private void ChangeSelectedRange(Dictionary<int, int> SelectedRange)
    // {
    //     product.SelectedRangesByStock = SelectedRange;
    // }

    // private void ChangeSelectedRange(List<int> SelectedRange)
    // {
    //     product.SelectedRanges = SelectedRange;
    // }

    // private void ChangeStock(int? stockId = null)
    // {
    //     product.StockId = stockId;
    // }
}