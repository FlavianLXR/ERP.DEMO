                                        <MudSelect @bind-Value="product.AlgorythmSerialNumber" Label="Algorithme numéro de série" Variant="Variant.Outlined" Dense Clearable>
                                            @if (serialNumberAlgorithms != null)
                                            {
                                                @foreach (var algo in serialNumberAlgorithms)
                                                {
