@using ERP.DEMO.ViewModels
@using MudBlazor

<MudDialog>
    <DialogContent>
        <code>@Content</code>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseDialog">Fermer</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public string? Content { get; set; }
    [CascadingParameter]
    private MudDialogInstance MudDialog { get; set; }
    private void CloseDialog() => MudDialog.Cancel();
}
