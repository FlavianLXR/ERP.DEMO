@page "/Login"
@inject LoginService LoginViewModel
@inject NavigationManager NavigationManager
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@using System.Security.Cryptography
@rendermode InteractiveServer
@inject ProtectedLocalStorage ProtectedLocalStorage


@if (login)
{
    <link rel="stylesheet" type="text/css" href="./assets/login/css/main.css">
    <link rel="stylesheet" type="text/css" href="./assets/login/css/util.css">
    <body>
        <div class="limiter">
            <div class="container-login100" style="background-color: #d7d7d7;">
                <div class="wrap-login100" style="box-shadow: 0 .1875rem .5rem 0 rgba(34,48,62,.1);">
                    <div class="login100-form-title" style="background-color:#fff">
                        <span class="login100-form-title-1">
                            Connexion
                        </span>
                    </div>
                    @if (loading)
                    {
                        <span class="loader_bar"></span>
                    }
                    <ErrorAlert Message="@error"/>
                    <EditForm class="login100-form validate-form" Model="@LoginViewModel" OnValidSubmit="() => LoginSubmit()" FormName="LoginForm">
                        <div class="wrap-input100 validate-input m-b-26" data-validate="Username is required">
                            <span class="label-input100" style="width:130px;left:-138px;top:7px"><MudIcon Icon="@Icons.Material.Outlined.AccountCircle" Size="Size.Large"></MudIcon></span>
                            <InputText class="input100" placeholder="Nom d'utilisateur" @bind-Value="LoginViewModel.username"></InputText>
                            @* <input class="input100" type="text" name="username" placeholder="Enter username"> *@
                            <ValidationMessage For="() => LoginViewModel.username"></ValidationMessage>
                            <span class="focus-input100"></span>
                        </div>

                        <div class="wrap-input100 validate-input m-b-18" data-validate="Password is required">
                            <span class="label-input100" style="width:130px;left:-138px;top:7px"><MudIcon Icon="@Icons.Material.Outlined.Lock" Size="Size.Large"></MudIcon></span>
                            <InputText type="password" placeholder="Mot de passe" class="input100" @bind-Value="LoginViewModel.password"></InputText>
                            <ValidationMessage For="() => LoginViewModel.password"></ValidationMessage>
                            @* <input class="input100" type="password" name="pass" placeholder="Enter password"> *@
                            <span class="focus-input100"></span>
                        </div>
                        <span style="color:red" class="mb-3">@LoginViewModel.errorMessage</span>
                        <div class="container-login100-form-btn">
                            <button class="login100-form-btn" type="submit">
                                Login
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </body>
}
else
{
    <div>
        <span style="margin: auto;display: flex;margin-top: 20%;" class="loader_spin"></span>
    </div>
}

@code {
    [CascadingParameter]
    public MainLayout Layout { get; set; }

    bool login = false;
    bool loading = false;
    string error;
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var result = await ProtectedLocalStorage.GetAsync<string>("authUser");
                if (result.Success)
                {
                    var result2 = await ProtectedLocalStorage.GetAsync<string>("authDate");
                    if (result2.Success)
                    {
                        var now = DateTime.Now;

                        // Convertir authDate en DateTime
                        if (DateTime.TryParse(result2.Value, out DateTime authDate))
                        {
                            // Calculer la différence
                            var difference = now - authDate;

                            // Vérifier si la différence est supérieure ŕ 30 minutes
                            if (difference.TotalMinutes > 30)
                            {
                                await LoginViewModel.Logout();

                            }
                            else
                            {
                                await LoginViewModel.SetAuthenticationStateAsync(result.Value);
                                if (LoginViewModel.isAuthenticated)
                                {
                                    return;
                                }
                            }
                        }
                    }
                }
                login = true;
                StateHasChanged();
            }
            catch (Exception e)
            {
                error = e.Message;
                await LoginViewModel.Logout(); // Reset complet, propre et cohérent
                login = true;
                StateHasChanged();
            }
        }
    }

    public async Task LoginSubmit()
    {
        try
        {

            loading = true;
            StateHasChanged();
            await Task.Delay(1); //Permet d'afficher le loader avant le await Login !
            await LoginViewModel.Login();
            if(!LoginViewModel.isAuthenticated)
            {
                _ = Task.Delay(500).ContinueWith(_ => InvokeAsync(() => {loading = false; StateHasChanged(); }));

            }
            else
            {
                loading = false;
                StateHasChanged();
            }
        }
        catch(Exception e)
        {
            error = e.Message;
        }
    }
}
