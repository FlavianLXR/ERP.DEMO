@page "/product/details/{Id:int}"
@inject ProductService ProductService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<div class="container-fluid py-2 pt-4">
    <div class="ms-3 me-3">
        <div class="row mb-3 d-flex flex-row" style="justify-content: space-between;place-items: center;">
            <div class="col">
                <h3 class="mb-0 mr-4 h4 font-weight-bolder">
                    <MudButton Variant="Variant.Text" title="Retour à l'index des articles" Style="align-items:center" OnClick="ViewProductIndex" StartIcon="@Icons.Material.Filled.ArrowBack"></MudButton>
                    <DisplayFor Model="product" For="p => p.Id" Class="text-dark font-weight-bold" />
                </h3>
                <style>
                    .mud-button-label .mud-button-icon-start {
                        margin-inline-end: 0px;
                    }
                </style>
            </div>
            <div class="col" style="text-align-last: right;">
                <MudIconButton Class="icon-button-class" Size="Size.Medium" title="Supprimer l'article (ne fonctionne pas)" OnClick="() => ViewProductDelete(product.Id)" Icon="@Icons.Material.Outlined.Delete"></MudIconButton>
            </div>
        </div>
