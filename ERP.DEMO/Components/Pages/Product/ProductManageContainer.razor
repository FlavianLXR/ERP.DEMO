@code {
    [Parameter] public Product Product { get; set; }
    [Parameter] public ProductService ProductService { get; set; }
    private string? selectedAlgorythm;
    private string? ErrorMessage;
    private EditFormGeneric<Product> form;
    private CollapseCard collapseCard;

    protected override void OnInitialized()
    {
        try
        {
            // selectedAlgorythm = ProductService.GetAlgorythms(Product);
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
    }

    private void Edit()
    {
        collapseCard.Collapsed = false;
        form.ToggleEdit();
        StateHasChanged();
    }
    private void CancelEdit()
    {
        collapseCard.Collapsed = false;
        form.CancelEdit();
        StateHasChanged();
    }
}