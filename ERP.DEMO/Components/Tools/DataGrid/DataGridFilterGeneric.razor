    #region FILTER VIEW
    /// <summary>
    /// Génère une vue de filtres à partir des filtres actuellement actifs sur l'index
    /// </summary>
    /// <param name="name">Nom de la vue de filtre</param>
    /// <returns>La vue de filtres actuelle</returns>
    private FilterView<object> GenerateFilterView(string name)
    {
        var ColumnHidden = DataGridToolBarGeneric.currentFilterView.Columns.ToDictionary(c => c.PropertyName, c => c.Hidden);

        var filterView = new FilterView<object>
            {
                Name = name,
                Filters = new List<Filter>(),
                IsSelected = true,
                OriginalTypeName = typeof(T).AssemblyQualifiedName,  // Stocker le type spécifique sous forme de chaîne
                ColumnOrder = DataGridToolBarGeneric.ColumnManagerComponent.GetColumnOrder(),
                Columns = DataGridToolBarGeneric.originalColumns
                                                .Select(c => new ColumnState<object>(
                                                    c.PropertyName,
                                                    c.Sortable,
                                                    c.Filterable,
                                                    c.Groupable,
                                                    c.Hideable,
                                                    ColumnHidden.ContainsKey(c.PropertyName) ? ColumnHidden[c.PropertyName] : false, // Utiliser la valeur du dictionnaire
                                                    c.HeaderTemplate as RenderFragment<HeaderContext<object>>
                                                )).ToList()
            };

        // Ajout des filtres string
        foreach (var filter in filterValuesString)
        {
            filterView.Filters.Add(new Filter
                {
                    PropertyName = filter.Key,
                    Value = filter.Value
                });
        }

        // Ajout des filtres int
        foreach (var filter in filterValuesInt)
        {
            filterView.Filters.Add(new Filter
                {
                    PropertyName = filter.Key,
                    Value = filter.Value
                });
        }

        // Ajout des filtres booléens
        foreach (var filter in filterValuesBool)
        {
            filterView.Filters.Add(new Filter
                {
                    PropertyName = filter.Key,
                    Operator = "=",
                    Value = filter.Value
                });
        }

        // Ajout des filtres dateTime
        foreach (var filter in filterValuesDateTime)
        {
            if (filter.Value.HasValue)
            {
                filterView.Filters.Add(new Filter
                    {
                        PropertyName = filter.Key,
                        Operator = "=",
                        Value = filter.Value.Value
                    });
            }
        }

        // Ajout des filtres date range
        foreach (var filter in filterValuesDateRangeTime)
        {
            filterView.Filters.Add(new Filter
                {
                    PropertyName = filter.Key,
                    Operator = "between",
                    Value = filter.Value, // Supposons que DateRange est un objet avec Start et End
                    DateRangeLabel = selectedRange
                });
        }

        // Ajout des filtres enum (liste de valeurs)
        foreach (var filter in filterValuesEnum)
        {
            filterView.Filters.Add(new Filter
                {
                    PropertyName = filter.Key,
                    Operator = "in",
                    Value = filter.Value.ToList()
                });
        }

        return filterView;
    }

    /// <summary>
    /// Sauvegarde en DB une vue de filtres à partir des filtres actuellement actifs sur l'index et sélectionne la vue comme active
    /// </summary>
    /// <param name="viewName">Nom de la vue de filtres</param>
    public async Task SaveFilterView(string viewName)
    {
        var savedFilter = GenerateFilterView(viewName);
        var existingFilter = filterViews.SingleOrDefault(x => x.Name == savedFilter.Name);

        if (existingFilter != null)
        {
            // Remplacer le filtre existant
            filterViews[filterViews.IndexOf(existingFilter)] = savedFilter;
        }
        else
        {
            // Ajouter le nouveau filtre si aucun n'existe avec ce nom
            filterViews.Add(savedFilter);
        }
        await SelectFilter(savedFilter);
        SetUserFilters();
    }

    /// <summary>
    /// Obtient la liste des vues de filtres sauvegardées par l'utilisateur
    /// </summary>
    private void GetUserFilters()
    {
        filterViews = new ObservableCollection<FilterView<object>>(
            DataGridToolBarGeneric.UserService.GetUserFilters()
            .Where(f => f.OriginalType == typeof(T))  // Filtre par OriginalType
            );
        DataGridToolBarGeneric.filterViews = filterViews;
    }

    /// <summary>
    /// Ajoute/supprime les vues de filtres de l'index actuelles aux autres vues sauvegardées par l'utilisateur
    /// </summary>
    public void SetUserFilters()
    {
        // Récupérer les filtres existants sauvegardés
        var currentFilters = DataGridToolBarGeneric.UserService.GetUserFilters();

        // Filtrer les filtres de type T et les remplacer par filterViews
        var filteredCurrentFilters = new ObservableCollection<FilterView<object>>(currentFilters.Where(f => f.OriginalType != typeof(T)).ToList());

        // Ajouter les nouveaux filtres filterViews
        foreach (var filterView in filterViews)
        {
            // Créer une copie du filtre et ajouter directement le filtre spécifique
            var objectFilterView = new FilterView<object>
                {
                    Filters = filterView.Filters,
                    Columns = filterView.Columns,
                    IsSelected = filterView.IsSelected,
                    Name = filterView.Name,
                    ColumnOrder = filterView.ColumnOrder,
                    OriginalTypeName = typeof(T).AssemblyQualifiedName  // Stocker le type spécifique sous forme de chaîne
                };
            filteredCurrentFilters.Add(objectFilterView);
        }

        DataGridToolBarGeneric.filterViews = filterViews;
        // Mettre à jour les SavedFilters avec la nouvelle liste
        DataGridToolBarGeneric.UserService.SetUserFilters(filteredCurrentFilters);
    }

    /// <summary>
    /// Active les filtres à partir d'une vue sélectionnée
    /// </summary>
    /// <param name="filterView">Nom de la vue de filtre</param>
    private async Task SetFilters(FilterView<object> filterView = null)
    {
        await RemoveAllFilters(false);
        if (filterView != null)
        {
            foreach (var filter in filterView.Filters)
            {

                switch (filter.Value)
                {
                    case JsonElement jsonElement when jsonElement.ValueKind == JsonValueKind.True || jsonElement.ValueKind == JsonValueKind.False:
                        filterValuesBool[filter.PropertyName] = jsonElement.GetBoolean();
                        break;

                    // Cas où la valeur est un JsonElement
                    case JsonElement jsonElement when jsonElement.ValueKind == JsonValueKind.String:
                        filterValuesString[filter.PropertyName] = jsonElement.GetString() ?? string.Empty;
                        break;

                    case JsonElement jsonElement when jsonElement.ValueKind == JsonValueKind.Number:
                        filterValuesString[filter.PropertyName] = jsonElement.GetRawText();
                        break;

                    case JsonElement jsonElement when jsonElement.ValueKind == JsonValueKind.Object:
                        if (/* filter.PropertyName.Contains("Date") &&  */jsonElement.TryGetProperty("Start", out var start) && jsonElement.TryGetProperty("End", out var end))
                        {
                            selectedRange = filter.DateRangeLabel ?? DateRangeLabel.last30days;
                            if (filter.DateRangeLabel.HasValue && filter.DateRangeLabel != DateRangeLabel.custom)
                            {
                                filterValuesDateRangeTime[filter.PropertyName] = GetDateRange(filter.DateRangeLabel);
                                break;
                            }
                            filterValuesDateRangeTime[filter.PropertyName] = new DateRange(start.GetDateTime(), end.GetDateTime());
                        }
                        if (jsonElement.TryGetProperty("Exact", out var exact) || jsonElement.TryGetProperty("Min", out var min) || jsonElement.TryGetProperty("Max", out var max))
                        {
                            if (!filterValuesInt.ContainsKey(filter.PropertyName)) filterValuesInt[filter.PropertyName] = new IntDictionnary();
                            if (!filterIntRange.ContainsKey(filter.PropertyName)) filterIntRange[filter.PropertyName] = false;

                            if (jsonElement.TryGetProperty("Exact", out exact))
                            {
                                filterValuesInt[filter.PropertyName].Exact = (exact.ValueKind != JsonValueKind.Null ? (exact.TryGetInt32(out int r) ? r : null) : null);
                            }

                            if (jsonElement.TryGetProperty("Min", out min))
                            {
                                filterValuesInt[filter.PropertyName].Min = (min.ValueKind != JsonValueKind.Null ? (min.TryGetInt32(out int r) ? r : null) : null);
                                if (filterValuesInt[filter.PropertyName].Min != null) filterIntRange[filter.PropertyName] = true;
                                if (filterValuesInt[filter.PropertyName].Exact == null) filterValuesInt[filter.PropertyName].Exact = filterValuesInt[filter.PropertyName].Min;
                            }
                            else if (filterValuesInt[filter.PropertyName].Exact != null)
                            {
                                filterValuesInt[filter.PropertyName].Min = filterValuesInt[filter.PropertyName].Exact;
                            }

                            if (jsonElement.TryGetProperty("Max", out max))
                            {
                                filterValuesInt[filter.PropertyName].Max = (max.ValueKind != JsonValueKind.Null ? (max.TryGetInt32(out int r) ? r : null) : null);
                                if (filterValuesInt[filter.PropertyName].Max != null) filterIntRange[filter.PropertyName] = true;
                            }
                        }
                        break;

                    case JsonElement jsonElement when jsonElement.ValueKind == JsonValueKind.Array:
                        if (!filterValuesEnum.ContainsKey(filter.PropertyName))
                        {
                            filterValuesEnum[filter.PropertyName] = new HashSet<string>();
                        }
                        foreach (var item in jsonElement.EnumerateArray())
                        {
                            filterValuesEnum[filter.PropertyName].Add(item.GetString() ?? string.Empty);
                        }
                        break;

                    // Cas où la valeur n'est pas un JsonElement
                    case string strValue:
                        filterValuesString[filter.PropertyName] = strValue;
                        break;

                    case int intValue:
                        filterValuesString[filter.PropertyName] = intValue.ToString();
                        break;
                    case IntDictionnary intDictionnaryValue:
                        if (!filterValuesInt.ContainsKey(filter.PropertyName))
                            filterValuesInt[filter.PropertyName] = new IntDictionnary();
                        filterValuesInt[filter.PropertyName].Max = intDictionnaryValue.Max;
                        filterValuesInt[filter.PropertyName].Exact = intDictionnaryValue.Exact;
                        filterValuesInt[filter.PropertyName].Min = intDictionnaryValue.Min;
                        break;
                    case double doubleValue:
                        filterValuesString[filter.PropertyName] = doubleValue.ToString();
                        break;

                    case bool boolValue:
                        filterValuesBool[filter.PropertyName] = boolValue;
                        break;

                    case DateTime dateTimeValue:
                        filterValuesDateTime[filter.PropertyName] = dateTimeValue;
                        break;

                    case DateRange dateRangeValue:
                        selectedRange = filter.DateRangeLabel ?? DateRangeLabel.last30days;
                        filterValuesDateRangeTime[filter.PropertyName] = dateRangeValue;
                        break;

                    case string[] strArray:
                        if (!filterValuesEnum.ContainsKey(filter.PropertyName))
                        {
                            filterValuesEnum[filter.PropertyName] = new HashSet<string>();
                        }
                        foreach (var item in strArray)
                        {
                            filterValuesEnum[filter.PropertyName].Add(item);
                        }
                        break;

                    case List<string> strList:
                        if (!filterValuesEnum.ContainsKey(filter.PropertyName))
                        {
                            filterValuesEnum[filter.PropertyName] = new HashSet<string>();
                        }
                        foreach (var item in strList)
                        {
                            filterValuesEnum[filter.PropertyName].Add(item);
                        }
                        break;
                }

                if (!selectedColumns.Contains(filter.PropertyName))
                {
                    selectedColumns.Add(filter.PropertyName);
                }
            }
        }
        await ApplyFilter();
    }

    public async Task SelectDefaultFilterView()
    {
        await SelectFilter();
    }

