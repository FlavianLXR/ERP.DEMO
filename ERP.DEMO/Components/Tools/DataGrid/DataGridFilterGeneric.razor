    #region ENUM
    /// <summary>
    /// Obtient le status IsChecked pour un attribut d'un filtre ENUM
    /// </summary>
    /// <param name="property">Nom de la colonne (type ENUM)</param>
    /// <param name="value">Attribut de l'ENUM</param>
    /// <returns>L'état IsChecked de l'attribut du filtre ENUM</returns>
    private bool IsChecked(string property, string value)
    {
        return filterValuesEnum.ContainsKey(property) && filterValuesEnum[property].Contains(value);
    }

    /// <summary>
    /// Décoche les attributs cochés d'un filtre ENUM
    /// </summary>
    /// <param name="property">Nom de la colonne (type ENUM)</param>
    private async Task ClearSelection(string property)
    {
        if (filterValuesString.ContainsKey(property))
            filterValuesString.Remove(property);
        if (filterValuesInt.ContainsKey(property))
            filterValuesInt.Remove(property);
        if (filterValuesDateRangeTime.ContainsKey(property))
            filterValuesDateRangeTime.Remove(property);
        if (filterValuesDateTime.ContainsKey(property))
            filterValuesDateTime.Remove(property);
        if (filterValuesBool.ContainsKey(property))
            filterValuesBool.Remove(property);
        if (filterValuesEnum.ContainsKey(property))
            filterValuesEnum[property].Clear();

        await ApplyFilter();

    }
