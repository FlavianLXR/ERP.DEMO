    /// Filtre l'index sur une recherche globale
    /// </summary>
    /// <param name="text">Contenu de la recherche global</param>
    private async Task OnSearch(string text)
    {
        // OrderViewModel._searchString = text;
        filterValuesString["GlobalSearch"] = text;
        await ApplyFilter();
    }

    /// <summary>
    /// Applique les filtres et recharge l'index
    /// </summary>
    private async Task ApplyFilter()
    {
        List<IFilterDefinition<T>> filters = new();

        // Filtrage pour les types string
        foreach (var filterEntry in filterValuesString)
        {
            string propertyName = filterEntry.Key;
            object filterValue = filterEntry.Value;

            var column = DataGrid.RenderedColumns.FirstOrDefault(x => x.PropertyName == propertyName);
            if (column == null || filterValue == null || string.IsNullOrWhiteSpace(filterValue.ToString()))
                continue;

            filters.Add(new FilterDefinition<T>()
                {
                    Id = Guid.NewGuid(),
                    Operator = "contains",
                    Value = filterValue,
                    Title = propertyName,
                    Column = column
                });
        }

        // Filtrage pour les types int
        foreach (var filterEntry in filterValuesInt)
        {
            string propertyName = filterEntry.Key;
            IntDictionnary filterValue = filterEntry.Value;

            var column = DataGrid.RenderedColumns.FirstOrDefault(x => x.PropertyName == propertyName);
            if (column == null || filterValue == null)
                continue;
            if (!filterIntRange.ContainsKey(propertyName))
            {
                filterIntRange[propertyName] = false;
            }
            if (filterIntRange[propertyName])
            {
                filters.Add(new FilterDefinition<T>()
                    {
                        Id = Guid.NewGuid(),
                        Operator = "<=",
                        Value = filterValue?.Max,
                        Title = propertyName,
                        Column = column
                    });

                filters.Add(new FilterDefinition<T>()
                    {
                        Id = Guid.NewGuid(),
                        Operator = ">=",
                        Value = filterValue?.Min,
                        Title = propertyName,
                        Column = column
                    });
            }
            else
            {
                filters.Add(new FilterDefinition<T>()
                    {
                        Id = Guid.NewGuid(),
                        Operator = "==",
                        Value = filterValue?.Exact,
                        Title = propertyName,
                        Column = column
                    });
            }
        }

        // Filtrage pour les types bool
        foreach (var filterEntry in filterValuesBool)
        {
            string propertyName = filterEntry.Key;
            object filterValue = filterEntry.Value;

            var column = DataGrid.RenderedColumns.FirstOrDefault(x => x.PropertyName == propertyName);
            if (column == null || filterValue == null)
                continue;

            filters.Add(new FilterDefinition<T>()
                {
                    Id = Guid.NewGuid(),
                    Operator = "==",
                    Value = filterValue,
                    Title = propertyName,
                    Column = column
                });
        }

        // Filtrage pour les enums (multi-sélection)
        foreach (var filterEntry in filterValuesEnum)
        {
            string propertyName = filterEntry.Key;
            var values = filterEntry.Value;

            var column = DataGrid.RenderedColumns.FirstOrDefault(x => x.PropertyName == propertyName);
            if (column == null || values == null || !values.Any())
                continue;

            foreach (var value in values)
            {
                filters.Add(new FilterDefinition<T>()
                    {
                        Id = Guid.NewGuid(),
                        Operator = "==",
                        Value = value,
                        Title = propertyName,
                        Column = column
                    });
            }
        }

        // Filtrage pour les types DateTimeRange
        foreach (var filterEntry in filterValuesDateTime)
        {
            string propertyName = filterEntry.Key;
            object filterValue = filterEntry.Value;

            var column = DataGrid.RenderedColumns.FirstOrDefault(x => x.PropertyName == propertyName);
            if (column == null || filterValue == null)
                continue;

            if (filterValue is DateTime singleDate)
            {
                filters.Add(new FilterDefinition<T>()
                    {
                        Id = Guid.NewGuid(),
                        Operator = ">=",
                        Value = singleDate.Date,
                        Title = propertyName,
                        Column = column
                    });
            }
        }

        // Filtrage pour les plages de dates
        foreach (var filterEntry in filterValuesDateRangeTime)
        {
            string propertyName = filterEntry.Key;
            var dateRange = filterEntry.Value;

            var column = DataGrid.RenderedColumns.FirstOrDefault(x => x.PropertyName == propertyName);
            if (column == null || dateRange == null)
                continue;

            if (dateRange.Start.HasValue)
            {
                filters.Add(new FilterDefinition<T>()
                    {
                        Id = Guid.NewGuid(),
                        Operator = ">=",
                        Value = dateRange.Start.Value.Date,
                        Title = $"{propertyName} (Start)",
                        Column = column
                    });
            }

            if (dateRange.End.HasValue)
            {
                filters.Add(new FilterDefinition<T>()
                    {
                        Id = Guid.NewGuid(),
                        Operator = "<",
                        Value = dateRange.End.Value.AddDays(1).Date,
                        Title = $"{propertyName} (End)",
                        Column = column
                    });
            }
        }

        // Filtrage pour la barre de recherche
        if (filterValuesString.TryGetValue("GlobalSearch", out var searchValue))
        {
            if (string.IsNullOrEmpty(searchValue)) searchValue = "";
            foreach (var column in DataGrid.RenderedColumns.Where(c => c.GetType().GetGenericArguments()[1] == typeof(string) && !c.Hidden))
            {
                filters.Add(new FilterDefinition<T>
                    {
                        Id = Guid.NewGuid(),
                        Operator = "contains",
                        Value = searchValue,
                        Title = "Recherche globale",
                        Column = column
                    });
            }
        }

        DataGrid.FilterDefinitions = filters;
        await DataGrid?.ReloadServerData();
        StateHasChanged();
    }

    /// <summary>
    /// Obtient l'égalité entre deux liste/ENUM
    /// </summary>
    /// <param name="list1">Première liste/ENUM</param>
    /// <param name="list2">Deuxième liste/ENUM</param>
    /// <returns>l'égalité entre deux liste/ENUM</returns>
    private bool AreFiltersEqual(List<Filter> list1, List<Filter> list2)
    {
        if (list1.Count != list2.Count)
            return false;

        var sortedList1 = list1.OrderBy(f => f.PropertyName)
                               .ThenBy(f => f.Operator)
                               .ThenBy(f => f.Value?.ToString())
                               .ToList();

        var sortedList2 = list2.OrderBy(f => f.PropertyName)
                               .ThenBy(f => f.Operator)
                               .ThenBy(f => f.Value?.ToString())
                               .ToList();

        for (int i = 0; i < sortedList1.Count(); i++)
        {
            // Ignorer "GlobalSearch"
            if (sortedList1[i].PropertyName == "GlobalSearch" || sortedList2[i].PropertyName == "GlobalSearch")
            {
                continue;
            }

            // Comparer les PropertyName et Operator
            if (sortedList1[i].PropertyName != sortedList2[i].PropertyName ||
                sortedList1[i].Operator != sortedList2[i].Operator)
            {
                return false;
            }

            // Comparer Value en tenant compte du type
            var value1 = sortedList1[i].Value;
            var value2 = sortedList2[i].Value;

            //Comparaison si valeur is IntDictionnary
            if (value1 is JsonElement jsonElement1 && jsonElement1.ValueKind == JsonValueKind.Object) value1 = GetIntDictionnaryFromJsonElement(jsonElement1) ?? value1;
            if (value2 is JsonElement jsonElement2 && jsonElement2.ValueKind == JsonValueKind.Object) value2 = GetIntDictionnaryFromJsonElement(jsonElement2) ?? value2;
            if (value1 is IntDictionnary intDictionnary1 && value2 is IntDictionnary intDictionnary2)
            {
                if (intDictionnary1.Exact != intDictionnary2.Exact || intDictionnary1.Min != intDictionnary2.Min || intDictionnary1.Max != intDictionnary2.Max)
                {
                    return false;
                }
                continue;
            }

            //Comparaison si valeur is DateRange
            if (value1 is JsonElement jsonElement3 && jsonElement3.ValueKind == JsonValueKind.Object) value1 = GetDateRangeFromJsonElement(jsonElement3) ?? value1;
            if (value2 is JsonElement jsonElement4 && jsonElement4.ValueKind == JsonValueKind.Object) value2 = GetDateRangeFromJsonElement(jsonElement4) ?? value2;
            if (value1 is DateRange dateRange1 && value2 is DateRange dateRange2)
            {
                if (dateRange1.Start != dateRange2.Start || dateRange1.End != dateRange2.End)
                {
                    return false;
                }
                continue;
            }

            // Comparer si les valeurs sont des tableaux JSON (JsonArray) et des collections C#
            if (value1 is JsonElement jsonElement5 && jsonElement5.ValueKind == JsonValueKind.Array) value1 = GetArrayFromJsonElement(jsonElement5) ?? value1;
            if (value2 is JsonElement jsonElement6 && jsonElement6.ValueKind == JsonValueKind.Array) value2 = GetArrayFromJsonElement(jsonElement6) ?? value2;
            if (value1 is IEnumerable<string> collection1 && value2 is IEnumerable<string> collection2)
            {
                if (!collection1.SequenceEqual(collection2))
                {
                    return false;
                }
                continue;
            }

            // Comparaison pour tous les autres types
            if (value1?.ToString() != value2?.ToString())
            {
                return false;
            }
        }
        return true;
    }

