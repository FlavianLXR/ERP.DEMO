@typeparam T

@using static Models.TestDb.Order
@using System.Text.Json;


@if (DataGridToolBarGeneric.switchGeneric == DataGridToolBarGeneric<T>.switchGenericEnum.ColumnManager)
{
    disabled = true;
}
else disabled = false;

@if (!isSearching)
{
    <div style="gap:0.25rem;display:flex;padding-top:0.5rem;flex-wrap: wrap;">
        @if (defaultFilterView.IsSelected == false)
        {
            @if (!string.IsNullOrEmpty(DataGridToolBarGeneric.propertyNameDefaultDateFilter))
            {
                <MudTooltip Arrow="true" Placement="Placement.Top" Class="mud-tooltip-class">
                    <ChildContent>
                        <MudButton Ripple="false" Class="filterView" @onclick="async () => await SelectFilter(defaultFilterView)" Disabled=disabled>
                            @defaultFilterView.Name
                            <MudIcon Size="Size.Small" Icon="@Icons.Material.Outlined.Info" Class="" />
                        </MudButton>
                    </ChildContent>
                    <TooltipContent>
                        Un filtre de date est appliqué par défaut sur cette vue, <br />
                        il est modifiable dans les paramètres utilisateurs ou dans les filtres de la vue.
                    </TooltipContent>
                </MudTooltip>
            }
            else
            {
                <MudButton Ripple="false" Class="filterView" @onclick="async () => await SelectFilter(defaultFilterView)" Disabled=disabled>
                    @defaultFilterView.Name
                </MudButton>

            }
        }
        else
        {
            @if (!string.IsNullOrEmpty(DataGridToolBarGeneric.propertyNameDefaultDateFilter))
            {

                <MudTooltip Arrow="true" Placement="Placement.Top" Class="mud-tooltip-class" Style="background-color: white;
    color: rgba(48, 48, 48, 1);
    border-radius: .5rem;
    box-shadow: 0rem .5rem 1.5rem -.5rem rgba(0, 0, 0, .28), 0rem .5rem 1rem -.25rem rgba(0, 0, 0, .05), 0rem .1875rem .375rem 0rem rgba(0, 0, 0, .05), 0rem .125rem .25rem 0rem rgba(0, 0, 0, .05), 0rem .0625rem .125rem 0rem rgba(0, 0, 0, .05), 0rem 0rem 0rem .0625rem rgba(0, 0, 0, .06); margin:0; font-size:.8125rem;">
                    <ChildContent>
                        <MudButton Ripple="false" Class="filterViewSelected" Style="padding: 0.25rem 0.75rem;" @onclick="async () => await SelectFilter(defaultFilterView)" Disabled=disabled>
                            @defaultFilterView.Name
                            <MudIcon Size="Size.Small" Icon="@Icons.Material.Outlined.Info" Class="" />
                        </MudButton>
                    </ChildContent>
                    <TooltipContent>
                        Un filtre de date est appliqué par défaut sur cette vue, <br />
                        il est modifiable dans les paramètres utilisateurs ou dans les filtres de la vue.
                    </TooltipContent>
                </MudTooltip>
            }
            else
            {
                <MudButton Ripple="false" Class="filterViewSelected" Style="padding: 0.25rem 0.75rem;" @onclick="async () => await SelectFilter(defaultFilterView)" Disabled=disabled>
                    @defaultFilterView.Name
                </MudButton>
            }
        }
        @if (filterViews != null && filterViews.Count > 0)
        {
            @foreach (var filterView in filterViews)
            {
                @if (!filterView.IsSelected)
                {
                    <MudButton Ripple="false" Class="filterView" @onclick="async () => await SelectFilter(filterView)" Disabled=disabled>
                        @filterView.Name
                    </MudButton>
                }
                else
                {
                    <MudMenu Ripple="false" Class="filterViewSelected" EndIcon="@Icons.Material.Filled.ArrowDropDown" Label="@filterView.Name" AnchorOrigin="MudBlazor.Origin.BottomLeft" TransformOrigin="MudBlazor.Origin.TopLeft" Disabled=disabled>
                        <MudMenuItem @onclick="() => OpenDialog(Dialog.Duplicate, filterView)">Dupliquer</MudMenuItem>
                        <MudMenuItem @onclick="() => OpenDialog(Dialog.Rename, filterView)">Renommer</MudMenuItem>
                        <MudMenuItem @onclick="() => DeleteFilterView(filterView)">Supprimer</MudMenuItem>
                    </MudMenu>
                }
            }
        }
        <MudTooltip Arrow="true" Placement="Placement.Top" Class="mud-tooltip-class" Text="Créer une vue"><MudButton Class="ToolbarButton" @onclick="() => OpenDialog(Dialog.Create)" Disabled=disabled><MudIcon Icon="@Icons.Material.Outlined.Add" /></MudButton></MudTooltip>
        <MudDialog @bind-Visible="_openDialog" DefaultFocus="DefaultFocus.FirstChild">
            <TitleContent>
                @if (typeDialog == Dialog.Create)
                {
                    @("Créer une nouvelle vue")
                }
                @if (typeDialog == Dialog.Rename)
                {
                    @("Renommer la vue")
                }
                @if (typeDialog == Dialog.Duplicate)
                {
                    @("Dupliquer la vue")
                }
            </TitleContent>
            <DialogContent>
                @if (dialogError)
                {
                    <MudAlert Severity="Severity.Error" Dense="true" Class="my-2">@dialogErrorText</MudAlert>
                }
                <MudTextField Label="Nom de la vue" @bind-Value="viewName" Immediate Variant="Variant.Filled" @onkeydown="HandleKeyDown" />
            </DialogContent>
            <DialogActions>
                <MudButton Color="Color.Error" @onclick="() => CloseDialog()">Annuler</MudButton>
                @if (typeDialog == Dialog.Create)
                {
                    <MudButton Color="Color.Primary" @onclick="async () => await CreateFilterView()" Disabled="!ValidateViewName()">Confirmer</MudButton>
                }
                @if (typeDialog == Dialog.Rename)
                {
                    <MudButton Color="Color.Primary" @onclick="() => RenameFilterView(dialogFilterView)" Disabled="!ValidateViewName()">Confirmer</MudButton>

                }
                @if (typeDialog == Dialog.Duplicate)
                {
                    <MudButton Color="Color.Primary" @onclick="async () => await DuplicateFilterView(dialogFilterView)" Disabled="!ValidateViewName()">Confirmer</MudButton>
                }
            </DialogActions>
        </MudDialog>
    </div>
    <MudSpacer />
    <div style="align-self: flex-start;margin-top: 0.5rem;margin-left:0.25rem!important">
        @if (DataGridToolBarGeneric.switchGeneric == DataGridToolBarGeneric<T>.switchGenericEnum.Default)
        {
            <MudTooltip Arrow="true" Placement="Placement.Top" Class="mud-tooltip-class" Text="Rechercher et filtrer"><MudButton Class="ToolbarButton" Style="" @onclick="() => ToggleSearch(true)"><MudIcon Icon="@Icons.Material.Outlined.Search" /><MudIcon Icon="@Icons.Material.Outlined.FilterList" /></MudButton></MudTooltip>
        }
    </div>
    <style type="text/css">
        .mud-toolbar.mud-toolbar-gutters.mud-table-toolbar {
            flex-flow: wrap;
        }

        .mud-button-icon-end {
            margin-left: 0 !important;
            margin-inline-start: 0 !important;
        }
    </style>
}
else
{
    <style type="text/css">
        .mud-toolbar.mud-toolbar-gutters.mud-table-toolbar {
            display: flex;
            height: auto;
            flex-direction: column;
        }
    </style>

    <div class="row pt-3" style="width:100%">
        <div class="col">
            <MudTextField T="string" ValueChanged="@(async (s) => await OnSearch(s.ToString()))" Placeholder="Rechercher"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" DebounceInterval="400"
                          IconSize="MudBlazor.Size.Medium" Class="mt-0" Style="margin-right:20px" />
        </div>
        <div class="col-auto ml-auto">
            <MudButton Ripple="false" Color="MudBlazor.Color.Error" OnClick="async () => await CancelSaveFilterButton()">Annuler</MudButton>
            @if (currentFilterView.Name == "Tous")
            {
                <MudButton Ripple="false" Color="Color.Success" Disabled="GetEditStateFilterView()" OnClick="() => OpenDialog(Dialog.SaveAs)">Enregistrer sous</MudButton>
                <MudDialog @ref="saveAsDialog" @bind-Visible="_openDialogSaveAs" DefaultFocus="DefaultFocus.FirstChild">
                    <TitleContent>
                        @("Enregistrer la vue sous")
                    </TitleContent>
                    <DialogContent>
                        @if (dialogError)
                        {
                            <MudAlert Severity="Severity.Error" Dense="true" Class="my-2">@dialogErrorText</MudAlert>
                        }
                        <MudTextField Label="Nom de la vue" @bind-Value="viewName" Immediate Variant="Variant.Filled" @onkeydown="HandleKeyDown" />
                    </DialogContent>
                    <DialogActions>
                        <MudButton Ripple="false" Color="Color.Secondary" @onclick="() => CloseDialog()">Annuler</MudButton>
                        <MudButton Ripple="false" Color="Color.Primary" @onclick="async () => await ConfirmSaveAsFilterButton()" Disabled="!ValidateViewName()">Enregistrer</MudButton>
                    </DialogActions>
                </MudDialog>

            }
            else
            {
                <MudButton Ripple="false" Color="Color.Success" Disabled="GetEditStateFilterView()" OnClick="async () => await ConfirmSaveFilterButton()">Enregistrer</MudButton>
            }
        </div>
    </div>
    <div class="row" style="margin-right:auto">
        <div class="col d-flex" style="flex-wrap: wrap;gap:.25rem;padding: .375rem .5rem 0 .5rem;">
            @foreach (var column in DataGrid.RenderedColumns)
            {
                System.Type type_ = column.GetType();
                System.Type[] genericArgs = type_.GetGenericArguments();
                System.Type type = genericArgs.Length > 1 ? genericArgs[1] : genericArgs[0];
                System.Type underlyingType = Nullable.GetUnderlyingType(type) ?? type;
                if (underlyingType?.IsEnum == true) LoadUniqueValues(column.PropertyName);

                @if (selectedColumns.Contains(column.PropertyName))
                {
                    <div>
                        <MudButton Ripple="false" Class="@(HasFilterValue(column.PropertyName) ? "filterAdded": "filter")" OnClick="() => TogglePopover(column.PropertyName)">
                            @(!HasFilterValue(column.PropertyName) ? column.Title : column.Title + ": " + GetFilterValue(column.PropertyName))
                            <MudButton Style="padding: 0;min-width: unset;" OnClick="() => RemoveColumnToFilter(column.PropertyName, true)"><MudIcon Size="Size.Small" Icon="@Icons.Material.Filled.Close" /></MudButton>
                        </MudButton>
                        <MudOverlay @bind-Visible="_open" AutoClose="true" OnClosed="() => TogglePopover()" />
                        <MudPopover Open="@(openFilter == column.PropertyName && _open)" MaxHeight="300"
                                    AnchorOrigin="MudBlazor.Origin.BottomLeft" TransformOrigin="MudBlazor.Origin.TopLeft" Class="filterPopover" Style="">
                            
                            @* <MudMenu Label="@filter.Title" AnchorOrigin="MudBlazor.Origin.BottomLeft" TransformOrigin="MudBlazor.Origin.TopLeft" EndIcon="@Icons.Material.Filled.Add"> *@
                            @if (type == typeof(string) || underlyingType == typeof(string))
                            {
                                if (!filterValuesString.ContainsKey(column.PropertyName))
                                {
                                    filterValuesString[column.PropertyName] = string.Empty; // Initialisation par défaut
                                }
                                @* <MudTextField T="string" @bind-Value="filterValuesString[filter.PropertyName]"
                Placeholder="@filter.Title"
                Immediate="true"/> *@
                                <MudTextField AutoFocus T="string" Value="filterValuesString[column.PropertyName]"
                                              Placeholder="@column.Title"
                                              ValueChanged="async (e) => await AddFilter(column.PropertyName, e, FilterDictionary.FilterValuesString)" />
                            }
                            else if (type == typeof(int) || underlyingType == typeof(int))
                            {
                                if (!filterValuesInt.ContainsKey(column.PropertyName))
                                {
                                    filterValuesInt[column.PropertyName] = new IntDictionnary(); // Initialisation par défaut
                                }
                                if (!filterIntRange.ContainsKey(column.PropertyName))
                                {
                                    if (filterValuesInt[column.PropertyName].Min.HasValue || filterValuesInt[column.PropertyName].Max.HasValue)
                                    {
                                        filterIntRange[column.PropertyName] = true;
                                    }
                                    else
                                    {
                                        filterIntRange[column.PropertyName] = false;
                                    }
                                }
                                isRange = filterIntRange[column.PropertyName];
                                <div class="row" style="gap:.25rem;padding-top:0!important">
                                    <div class="col" style="min-width: 10rem;padding-right:0!important">
                                        <MudButton Class="@(!isRange ? "filterFieldSelected" : "filterField")" Ripple="false" OnClick="async () => await SetFilterIntRange(column.PropertyName, false)">Valeur exacte</MudButton>
                                    </div>
                                    <div class="col" style="min-width: 10rem;padding-left:0!important">
                                        <MudButton Class="@(isRange ? "filterFieldSelected" : "filterField")" Ripple="false" OnClick="async () => await SetFilterIntRange(column.PropertyName, true)">Plage de valeurs</MudButton>
                                    </div>
                                </div>
                                <div style="align-items: center;display: flex;justify-content: center;flex-direction: row;">
                                    @if (!filterIntRange[column.PropertyName])
                                    {
                                        <MudNumericField AutoFocus T="int?" Value="filterValuesInt[column.PropertyName].Exact" HideSpinButtons="true"
                                                         Placeholder="@column.Title" OnKeyDown="(e) => enterKeyPressed(e, column.PropertyName, IntRangeValue.Exact)" Immediate
                                                         ValueChanged="async (e) => await AddFilter(column.PropertyName, new IntDictionnary { Exact = e }, FilterDictionary.FilterValuesInt)" />
                                    }
                                    else
                                    {
                                        <MudNumericField AutoFocus T="int?" Value="filterValuesInt[column.PropertyName].Min" HideSpinButtons="true"
                                                         Placeholder="Min" OnKeyDown="(e) => enterKeyPressed(e, column.PropertyName, IntRangeValue.Min, true)" Immediate
                                                         ValueChanged="async (e) => await AddFilter(column.PropertyName, new IntDictionnary { Min = e, Max = filterValuesInt[column.PropertyName].Max }, FilterDictionary.FilterValuesInt, intRange: true)" />

                                        <MudText Typo="Typo.body1" Class="mx-2">à</MudText>

                                        <MudNumericField T="int?" Value="filterValuesInt[column.PropertyName].Max" HideSpinButtons="true"
                                                         Placeholder="Max" OnKeyDown="(e) => enterKeyPressed(e, column.PropertyName, IntRangeValue.Max, true)" Immediate
                                                         ValueChanged="async (e) => await AddFilter(column.PropertyName, new IntDictionnary { Min = filterValuesInt[column.PropertyName].Min, Max = e }, FilterDictionary.FilterValuesInt, intRange: true)" />
                                    }
                                </div>
                            }
                            else if (type == typeof(bool) || underlyingType == typeof(bool))
                            {
                                if (!filterValuesBool.ContainsKey(column.PropertyName))
                                {
                                    filterValuesBool[column.PropertyName] = true; // Initialisation par défaut
                                }
                                <MudCheckBox T="bool" Size="Size.Small" Value="filterValuesBool[column.PropertyName]"
                                             Label="@column.Title"
                                             ValueChanged="async (e) => await AddFilter(column.PropertyName, e, FilterDictionary.FilterValuesBool)" />
                            }
                            else if (underlyingType == typeof(DateTime))
                            {
                                <p>@column.Title</p>
                                if (!filterValuesDateTime.ContainsKey(column.PropertyName))
                                {
                                    filterValuesDateTime[column.PropertyName] = null; // Initialisation par défaut
                                }
                                if (!filterValuesDateRangeTime.ContainsKey(column.PropertyName))
                                {
                                    selectedRange = DateRangeLabel.last30days;
                                    filterValuesDateRangeTime[column.PropertyName] = GetDateRange(selectedRange); // Initialisation par défaut
                                    HandleRangeChanged(column.PropertyName, FilterDictionary.FilterValuesDateRangeTime, true);
                                }
                                @*  <MudDatePicker @bind-Date="filterValuesDateTime[filter.PropertyName]" Placeholder="@filter.Title"
                Immediate="true" />
                <MudDateRangePicker @bind-DateRange="filterValuesDateRangeTime[filter.PropertyName]" Margin="Margin.Dense"
                PlaceholderStart="Start Date" PlaceholderEnd="End Date" Label="Range" />
                *@
                                @* ValueChanged = "(e) => AddFilter(filter.PropertyName, e, FilterDictionary.FilterValuesDateRangeTime)" *@
                                <MudRadioGroup T="DateRangeLabel" @bind-value="selectedRange" @bind-value:after="async ()=> await HandleRangeChanged(column.PropertyName, FilterDictionary.FilterValuesDateRangeTime)" Style="flex-direction:row;display:flex">
                                    @*                     <MudRadioGroup T="string" @bind-Value="selectedRange" Style="flex-direction:row;display:flex"
                    @onchange="@(async (string e) => await HandleSelectedRangeChanged(e))">
                    *@
                                    <MudRadio Size="Size.Small" T="DateRangeLabel" Value=@(DateRangeLabel.today)>Aujourd'hui</MudRadio>
                                    <MudRadio Size="Size.Small" T="DateRangeLabel" Value=@(DateRangeLabel.last7days)>Les 7 derniers jours</MudRadio>
                                    <MudRadio Size="Size.Small" T="DateRangeLabel" Value=@(DateRangeLabel.last30days)>Le dernier mois</MudRadio>
                                    <MudRadio Size="Size.Small" T="DateRangeLabel" Value=@(DateRangeLabel.last90days)>Les 3 derniers mois</MudRadio>
                                    <MudRadio Size="Size.Small" T="DateRangeLabel" Value=@(DateRangeLabel.last12months)>Les 12 derniers mois</MudRadio>
                                    <MudRadio Size="Size.Small" T="DateRangeLabel" Value=@(DateRangeLabel.custom)>Personnalisée</MudRadio>
                                </MudRadioGroup>
                                @if (selectedRange == DateRangeLabel.custom)
                                {
                                    <MudDateRangePicker DateRange="filterValuesDateRangeTime[column.PropertyName]" AutoClose DateRangeChanged="(e) => AddFilter(column.PropertyName, e, FilterDictionary.FilterValuesDateRangeTime)" Margin="Margin.Dense"
                                                        PlaceholderStart="À partir du" PlaceholderEnd="Jusqu'à" Label="@column.Title" Clearable="true" />
                                }
                            }

                            else if (underlyingType?.IsEnum == true)
                            {
                                <p>@column.Title</p>
                                if (!filterValuesEnum.ContainsKey(column.PropertyName))
                                {
                                    filterValuesEnum[column.PropertyName] = new HashSet<string>();
                                }
                                // Charger les valeurs uniques pour les autres types
                                LoadUniqueValues(column.PropertyName);

                                @if (uniqueValues.ContainsKey(column.PropertyName))
                                {
                                    <div>
                                        @foreach (var value in uniqueValues[column.PropertyName])
                                        {
                                            <MudCheckBox T="bool" Value="IsChecked(column.PropertyName, value.Value)" Label="@value.Description"
                                                         ValueChanged="async (e) => await AddFilter(column.PropertyName, value.Value, FilterDictionary.FilterValuesEnum, e, value.Description)" />
                                        }
                                    </div>
                                }
                            }
                            @if (!(underlyingType == typeof(DateTime) || underlyingType == typeof(bool)) @* && selectedRange != DateRangeLabel.custom *@)
                            {
                                <div style="position:sticky;bottom:0;width:100%;justify-content:left;background:white;z-index:5">
                                    <MudButton Style="" Ripple="false" Disabled="@(HasFilterValue(column.PropertyName) ? false : true)" OnClick="async () => await ClearSelection(column.PropertyName)">Effacer</MudButton>
                                </div>
                            }
                        </MudPopover>
                    </div>
                    @* </MudMenu> *@
                }
            }
            <MudMenu @ref="AddFilterMudMenu" Ripple="false" MaxHeight="300" Dense="true" AnchorOrigin="MudBlazor.Origin.BottomLeft" TransformOrigin="MudBlazor.Origin.TopLeft">
                <ActivatorContent>
                    <MudButton Ripple="false" Style="padding: 1px 6px !important;transition: background-color 250ms cubic-bezier(0.4, 0, 0.2, 1) 0ms, box-shadow 250ms cubic-bezier(0.4, 0, 0.2, 1) 0ms, border 250ms cubic-bezier(0.4, 0, 0.2, 1) 0ms;" Class="filter">Ajouter un filtre<MudIcon Size="Size.Small" Icon="@Icons.Material.Filled.Add" /></MudButton>
                </ActivatorContent>
                <ChildContent>
                    <div class="p-3 pt-2">
                        <div style="position: sticky;top: 0;z-index: 1;background: #fff;">
                            <MudTextField OnKeyDown="async (e) => await HandleKeyDown(e)" AutoFocus T="string" @bind-Value="searchQuery" Placeholder="Rechercher une colonne" Immediate="true" />
                        </div>
                        @* <MudAutocomplete @bind-Value="searchQuery"></MudAutocomplete> *@
                        @foreach (var filter in DataGrid.RenderedColumns)
                        {
                            if (filter.Filterable != false && (string.IsNullOrEmpty(searchQuery) || filter.Title.Contains(searchQuery, StringComparison.OrdinalIgnoreCase)))
                            {
                                <MudMenuItem OnClick="() => AddColumnToFilter(filter.PropertyName)">
                                    @filter.Title
                                </MudMenuItem>
                            }
                        }
                    </div>
                </ChildContent>
            </MudMenu>
            <MudButton Ripple="false" OnClick="async () => await RemoveAllFilters()" Style="padding: 1px 6px !important;" Variant="Variant.Outlined" Color="Color.Error">Tout supprimer</MudButton>
        </div>
    </div>
}

<style type="text/css">
    .mud-menu > button.mud-button-root.mud-button {
        background-color: transparent !important;
    }

    .mud-tooltip-root {
        display: inherit !important;
    }
</style>

@code {
    #region Variables locales
    private List<string> selectedColumns = new();
    private ObservableCollection<FilterView<object>> filterViews = new();
    private List<ColumnState<object>> columnState = new();
    private FilterView<object> currentFilterView;
    private FilterView<object> defaultFilterView;
    private FilterView<object> dialogFilterView;
    private string searchQuery;
    private string openFilter = "";
    private bool _open;
    private bool _openDialog = false;
    private bool _openDialogSaveAs = false;
    private DateRangeLabel selectedRange;
    private string _searchString = "";
    private bool isSearching = false;
    private string viewName;
    private Dialog typeDialog;
    private MudDialog saveAsDialog;
    private MudMenu AddFilterMudMenu;
    private string dialogErrorText = "";
    private bool dialogError = false;
    private bool disabled = false;
    private bool enterKey = false;
    private bool isRange = false;
    #endregion

    #region Variables parents
    [CascadingParameter] public MudDataGrid<T> DataGrid { get; set; }
    [CascadingParameter] public DataGridToolBarGeneric<T> DataGridToolBarGeneric { get; set; }
    [CascadingParameter] public Layout.MainLayout MainLayout { get; set; }
    [Parameter] public string Title { get; set; }
    [Parameter] public string propertyNameDefaultDateFilter { get; set; }
    [Parameter] public DataGridViewModelGeneric<T> dataGridViewModelGeneric { get; set; }

    #endregion

    #region Variables de filtres
    private Dictionary<string, string> filterValuesString = new Dictionary<string, string>();
    private Dictionary<string, IntDictionnary> filterValuesInt = new Dictionary<string, IntDictionnary>();
    private Dictionary<string, bool> filterIntRange = new Dictionary<string, bool>();
    class IntDictionnary { public int? Exact { get; set; } public int? Min { get; set; } public int? Max { get; set; } }
    private Dictionary<string, DateRange> filterValuesDateRangeTime = new Dictionary<string, DateRange>();
    private Dictionary<string, DateTime?> filterValuesDateTime = new Dictionary<string, DateTime?>();
    private Dictionary<string, bool> filterValuesBool = new Dictionary<string, bool>();
    private Dictionary<string, HashSet<string>> filterValuesEnum = new();
    private Dictionary<string, List<(string Value, string Description)>> uniqueValues = new();
    private enum FilterDictionary
    {
        FilterValuesString,
        FilterValuesInt,
        FilterValuesBool,
        FilterValuesDateTime,
        FilterValuesDateRangeTime,
        FilterValuesEnum
    }
    private enum Dialog
    {
        Create,
        Duplicate,
        Rename,
        SaveAs
    }
    private enum IntRangeValue
    {
        Exact,
        Min,
        Max
    }
    #endregion

    /// <summary>
    /// Obtient la liste des vues, initialise les filtres la vue sélectionnée
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        defaultFilterView = DataGridToolBarGeneric.defaultFilterView;
        DataGridToolBarGeneric.OnStateChange += StateHasChanged; // Écoute les changements
        GetUserFilters();
        defaultFilterView.Columns = DataGrid.RenderedColumns.Select(c => new ColumnState<object>(
                    c.PropertyName,
                    c.Sortable,
                    c.Filterable,
                    c.Groupable,
                    c.Hideable,
                    c.Hidden, // Utiliser la valeur du dictionnaire
                    c.HeaderTemplate as RenderFragment<HeaderContext<object>>
                )).ToList();
        if (filterViews.Where(x => x.IsSelected == true).Count() == 1)
        {
            var filterView = filterViews.Where(x => x.IsSelected == true).FirstOrDefault();
            currentFilterView = filterView;
            DataGridToolBarGeneric.currentFilterView = currentFilterView;
            DataGridToolBarGeneric.SetHiddenColumns(currentFilterView);
            await SelectFilter(filterView);
            return;
        }
        defaultFilterView.IsSelected = true;
        currentFilterView = defaultFilterView ?? filterViews.FirstOrDefault();
        columnState = currentFilterView.Columns;
        DataGridToolBarGeneric.currentFilterView = currentFilterView;
        DataGridToolBarGeneric.SetHiddenColumns(currentFilterView);
        await SetFilters(currentFilterView);
    }

    #region FILTER
    /// <summary>
    /// Affiche le bouton de filtre d'une colonne
    /// </summary>
    /// <param name="propertyName">Nom de la colonne à afficher</param>
    private void AddColumnToFilter(string propertyName)
    {
        CleanUnusedFilters();
        if (!selectedColumns.Contains(propertyName))
        {
            selectedColumns.Add(propertyName);
            TogglePopover(propertyName);
        }
    }

    /// <summary>
    /// Supprime les valeurs de filtres de la colonne et cache le bouton du filtre
    /// </summary>
    /// <param name="propertyName">Nom de la colonne</param>
    /// <param name="refresh">Défini si l'index doit être rechargé (permet d'éviter de recharger plusieurs fois si on appel RemoveAllFilters)</param>
    private async void RemoveColumnToFilter(string propertyName, bool refresh)
    {
        selectedColumns.Remove(propertyName);
        filterValuesString.Remove(propertyName);
        filterValuesInt.Remove(propertyName);
        filterValuesDateRangeTime.Remove(propertyName);
        filterValuesDateTime.Remove(propertyName);
        filterValuesBool.Remove(propertyName);
        filterValuesEnum.Remove(propertyName);
        if (refresh)
            await ApplyFilter();
    }

    /// <summary>
    /// Supprime toutes les valeurs de filtres et cache tous les boutons de filtres
    /// </summary>
    /// <param name="refresh">Défini si l'index doit être rechargé (permet d'éviter de recharger plusieurs fois si on appel SetFilters ou CreateFilterView)</param>
    private async Task RemoveAllFilters(bool? refresh = true)
    {
        var columnsToRemove = selectedColumns.ToList();
        foreach (var column in columnsToRemove)
            RemoveColumnToFilter(column, false);
        if (refresh == true)
            await ApplyFilter();
    }

    /// <summary>
    /// Supprime les filtres sans valeurs
    /// </summary>
    private void CleanUnusedFilters()
    {
        var columnsToRemove = selectedColumns
            .Where(column => !HasFilterValue(column))
            .ToList();

        foreach (var column in columnsToRemove)
            RemoveColumnToFilter(column, false);
    }

    /// <summary>
    /// Obtient l'état filtré ou non d'une colonne
    /// </summary>
    /// <param name="propertyName">Nom de la colonne</param>
    /// <returns>L'état filtré d'une colonne</returns>
    private bool HasFilterValue(string propertyName)
    {
        return (filterValuesString.TryGetValue(propertyName, out var strVal) && !string.IsNullOrWhiteSpace(strVal))
            || (filterValuesInt.TryGetValue(propertyName, out var intVal) && (intVal.Exact != null || intVal.Min != null || intVal.Max != null))
            || (filterValuesBool.TryGetValue(propertyName, out var boolVal)) //&& boolVal) n'enlève pas la colonne si bool à false
            || (filterValuesDateTime.TryGetValue(propertyName, out var dateVal) && dateVal.HasValue)
            || (filterValuesDateRangeTime.TryGetValue(propertyName, out var rangeVal) && (rangeVal?.Start.HasValue == true || rangeVal?.End.HasValue == true))
            || (filterValuesEnum.TryGetValue(propertyName, out var enumVals) && enumVals.Any());
    }

    /// <summary>
    /// Obtient la valeur de filtre d'une colonne
    /// </summary>
    /// <param name="propertyName">Nom de la colonne filtrée</param>
    /// <returns>La valeur de filtre d'une colonne</returns>
    private string GetFilterValue(string propertyName)
    {
        List<string> values = new();

        if (filterValuesString.TryGetValue(propertyName, out var strVal) && !string.IsNullOrWhiteSpace(strVal))
            values.Add(strVal);

        if (filterValuesInt.TryGetValue(propertyName, out var intVal) && intVal != null)
        {
            string t = "";
            if (!filterIntRange[propertyName] && intVal.Exact.HasValue)
            {
                t = intVal.Exact.ToString();
            }
            else
            {
                if (intVal.Min.HasValue)
                {
                    t = "Supérieur à " + intVal.Min.ToString();
                    if (intVal.Max.HasValue)
                    {
                        t = intVal.Min.ToString() + " à " + intVal.Max.ToString();
                    }
                }
                else
                {
                    t = "Inférieur à " + intVal.Max.ToString();
                }
            }
            values.Add(t);
        }

        if (filterValuesBool.TryGetValue(propertyName, out var boolVal))
            values.Add(boolVal.ToString());

        if (filterValuesDateTime.TryGetValue(propertyName, out var dateVal) && dateVal.HasValue)
            values.Add(dateVal.Value.ToShortDateString());

        if (filterValuesDateRangeTime.TryGetValue(propertyName, out var rangeVal))
        {
            string t = "";
            if (rangeVal.Start.HasValue)
                t += (rangeVal.Start.Value.ToShortDateString());
            if (rangeVal.End.HasValue)
                t += ($" -> {rangeVal.End.Value.ToShortDateString()}");
            values.Add(t);
        }

        if (filterValuesEnum.TryGetValue(propertyName, out var enumVals) && enumVals.Any())
        {
            return string.Join(", ", enumVals.Select(val =>
                uniqueValues.ContainsKey(propertyName)
                    ? uniqueValues[propertyName].FirstOrDefault(x => x.Value == val).Description
                    : val
            ));
        }
        return string.Join(", ", values);
    }

    /// <summary>
    /// Stock la valeur d'un filtre d'une colonne
    /// </summary>
    /// <param name="propertyName">Nom de la colonne filtrée</param>
    /// <param name="value">Valeur du filtre</param>
    /// <param name="dictionaryName">Type du filtre</param>
    /// <param name="isChecked">Ajoute ou supprime la valeur d'un attribut d'un ENUM</param>
    private async Task AddFilter(string propertyName, object value, FilterDictionary dictionaryName, bool isChecked = true, string description = null, bool intRange = false, bool defaultSorting = false, bool togglePopover = false)
    {
        if (defaultSorting)
        {
            var defaultcolumn = DataGrid.GetColumnByPropertyName(propertyName);
            System.Type type_ = defaultcolumn.GetType();
            System.Type[] genericArgs = type_.GetGenericArguments();
            System.Type type = genericArgs.Length > 1 ? genericArgs[1] : genericArgs[0];
            System.Type underlyingType = Nullable.GetUnderlyingType(type) ?? type;

            if (underlyingType == typeof(DateTime))
            {
                //TODO METTRE LA DATE PAR DEFAULT EN FONCTION DES PREFERENCES UTILISATEURS
                filterValuesDateTime[propertyName] = DateTime.Today.AddDays(-30);
                if (!selectedColumns.Contains(propertyName))
                {
                    selectedColumns.Add(propertyName);
                }
                await ApplyFilter();
            }
            return;
        }
        switch (dictionaryName)
        {
            case FilterDictionary.FilterValuesString:
                filterValuesString[propertyName] = value.ToString();
                break;
            case FilterDictionary.FilterValuesInt:
                IntDictionnary e = (IntDictionnary)value;
                filterValuesInt[propertyName].Min = (isRange ? e.Min : e.Exact);
                filterValuesInt[propertyName].Max = (isRange ? e.Max : null);
                filterValuesInt[propertyName].Exact = (isRange ? e.Min : e.Exact);
                break;
            case FilterDictionary.FilterValuesBool:
                filterValuesBool[propertyName] = (bool)value;
                break;
            case FilterDictionary.FilterValuesDateTime:
                filterValuesDateTime[propertyName] = (DateTime?)value;
                break;
            case FilterDictionary.FilterValuesDateRangeTime:
                filterValuesDateRangeTime[propertyName] = GetDateRange(value);
                break;
            case FilterDictionary.FilterValuesEnum:
                if (!filterValuesEnum.ContainsKey(propertyName))
                    filterValuesEnum[propertyName] = new HashSet<string>();
                if (isChecked)
                    filterValuesEnum[propertyName].Add(value.ToString());
                else
                    filterValuesEnum[propertyName].Remove(value.ToString());
                break;
            default:
                throw new ArgumentException("Dictionnaire inconnu : " + dictionaryName);
        }

        // TogglePopover seulement si ce n'est pas Bool ou Enum ou Int
        if (dictionaryName != FilterDictionary.FilterValuesBool && dictionaryName != FilterDictionary.FilterValuesEnum && dictionaryName != FilterDictionary.FilterValuesInt && togglePopover != true)
        {
            TogglePopover();
        }

        await ApplyFilter();
    }

