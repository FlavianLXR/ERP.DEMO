    #region DATETIME

    /// <summary>
    /// Transpose le string du MudRadio en DateRange
    /// </summary>
    /// <param name="selectedRange">string représentant le filtre date</param>
    /// <returns>Le DateRange du filtre</returns>
    private DateRange GetDateRange(object selectedRange)
    {
        if (selectedRange == null) return null;
        if (selectedRange.GetType() == typeof(DateRangeLabel))
        {
            var selectedRangeDateRangeLabel = (DateRangeLabel)selectedRange;
            if (selectedRangeDateRangeLabel == DateRangeLabel.today)
            {
                return new DateRange(DateTime.Today, null);
            }
            else if (selectedRangeDateRangeLabel == DateRangeLabel.last7days)
            {
                return new DateRange(DateTime.Today.AddDays(-7), DateTime.Today);
            }
            else if (selectedRangeDateRangeLabel == DateRangeLabel.last30days)
            {
                return new DateRange(DateTime.Today.AddMonths(-1), DateTime.Today);
            }
            else if (selectedRangeDateRangeLabel == DateRangeLabel.last90days)
            {
                return new DateRange(DateTime.Today.AddMonths(-3), DateTime.Today);
            }
            else if (selectedRangeDateRangeLabel == DateRangeLabel.last12months)
            {
                return new DateRange(DateTime.Today.AddMonths(-12), DateTime.Today);
            }
            return null;
        }
        else if (selectedRange.GetType() == typeof(DateRange))
        {
            return (DateRange)selectedRange;
        }
        return null;
    }

    /// <summary>
    /// Applique le filtre date pour les MudRadio qui ne sont pas "custom/personnalisé" (ex: 7 jours, 30 jours...)
    /// </summary>
    /// <param name="propertyName">Nom de la colonne à filtrer</param>
    /// <param name="dictionaryName">Type de liste de filtres à stocker (FilterDictionary.FilterValuesDateRangeTime dans ce cas)</param>
    private async Task HandleRangeChanged(string propertyName, FilterDictionary dictionaryName, bool togglePopover = false)
    {
        if (selectedRange != DateRangeLabel.custom)
        {
            await AddFilter(propertyName, selectedRange, dictionaryName, togglePopover: togglePopover);
        }
    }
