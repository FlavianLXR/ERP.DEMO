    /// <summary>
    /// Sélectionne une vue de filtre pour mettre ses filtres actifs
    /// </summary>
    /// <param name="filterView">Vue de filtres à sélectionner</param>
    /// <returns>La vue de filtres actuelle</returns>
    private async Task SelectFilter(FilterView<object> filterView = null)
    {
        if (filterView == null)
        {
            // if (filterViews.Count > 0)
            // {
            //     filterView = filterViews.FirstOrDefault();
            //     filterView.IsSelected = true;
            // }
            defaultFilterView.IsSelected = true;
            currentFilterView = defaultFilterView;
        }
        else
        {
            defaultFilterView.IsSelected = false;
            filterView.IsSelected = true;
            currentFilterView = filterView; //Garder en mémoire le filterView avant modification pour gérer le bouton enregistrer
        }

        // Désélectionner tous les autres
        foreach (var item in filterViews)
        {
            if (item != filterView)
            {
                item.IsSelected = false;
            }
        }
        columnState = currentFilterView.Columns;
        DataGridToolBarGeneric.currentFilterView = currentFilterView;
        DataGridToolBarGeneric.originalColumns = currentFilterView.Columns
    .Cast<ColumnState<object>>()  // D'abord caster vers ColumnState<object>
    .Select(c => new ColumnState<T>(
        c.PropertyName,
        c.Sortable,
        c.Filterable,
        c.Groupable,
        c.Hideable,
        c.Hidden,
        c.HeaderTemplate as RenderFragment<HeaderContext<T>>
    ))  // Convertir en ColumnState<T> en passant chaque propriété au constructeur
    .ToList();
        DataGridToolBarGeneric.columnOrderSaved = currentFilterView.ColumnOrder;
        if (DataGridToolBarGeneric.ColumnManagerComponent != null)
            DataGridToolBarGeneric.ColumnManagerComponent.SetColumnOrder(false);
        DataGridToolBarGeneric.SetHiddenColumns(currentFilterView);
        SetUserFilters();
        await SetFilters(filterView);
    }

