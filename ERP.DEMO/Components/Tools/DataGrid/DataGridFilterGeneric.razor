    /// <summary>
    /// Ouvre le MudDialog
    /// </summary>
    /// <param name="dialog">Référence au MudDialog à ouvrir</param>
    /// <param name="filterView">Vue de filtre lié au MudDialog (pour duplicate, rename...)</param>
    private void OpenDialog(Dialog dialog, FilterView<object> filterView = null)
    {
        SetDialogError();
        if (filterView != null) dialogFilterView = filterView;
        typeDialog = dialog;
        viewName = (typeDialog == Dialog.Rename ? filterView.Name : string.Empty);
        if (dialog == Dialog.SaveAs) _openDialogSaveAs = true;
        else _openDialog = true;
    }

    /// <summary>
    /// Ferme le MudDialog actif
    /// </summary>
    private void CloseDialog()
    {
        _openDialog = false;
        _openDialogSaveAs = false;
        if (saveAsDialog != null)
        {
            saveAsDialog.CloseAsync();
        }
        SetDialogError();
        StateHasChanged();
    }

    /// <summary>
    /// Défini l'erreur sur le MudDialog
    /// </summary>
    /// <param name="state">status de l'erreur (erreur ou non)</param>
    /// <param name="text">texte de l'erreur à afficher</param>
    private void SetDialogError(bool state = false, string text = "")
    {
        dialogError = state;
        dialogErrorText = text;
    }

    /// <summary>
    /// Méthode de validation pour le nom de la vue
    /// </summary>
    private bool ValidateViewName(/* string name = null */)
    {
        // if (!string.IsNullOrEmpty(name)) viewName = name;
        viewName = viewName.Trim();
        if (string.IsNullOrEmpty(viewName))
        {
            SetDialogError(true, "Le nom de la vue ne peut pas être vide.");
            return false;
        }
        //A REFACTORISER - dialogDilterView peut etre null si on clique sur le bouton add. Donc ne pas faire le where.
        if (dialogFilterView != null)
        {
            if (filterViews.Where(f => f.Name != dialogFilterView.Name).Any(f => f.Name.Equals(viewName, StringComparison.OrdinalIgnoreCase)))
            {
                SetDialogError(true, "Une vue avec ce nom existe déjà.");
                return false;
            }
        }
        else
        {
            if (filterViews.Any(f => f.Name.Equals(viewName, StringComparison.OrdinalIgnoreCase)))
            {
                SetDialogError(true, "Une vue avec ce nom existe déjà.");
                return false;
            }
        }
        SetDialogError(); // Reset erreurs si valide
        return true;
    }

    /// <summary>
    /// Confirme le MudDialog si touche "Entrer" appuyée
    /// </summary>
    /// <param name="e">Evenemment du clavier</param>
    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            // Déclenche le clic sur le bouton Confirmer
            if (typeDialog == Dialog.Create)
            {
                await CreateFilterView();
            }
            else if (typeDialog == Dialog.Rename)
            {
                RenameFilterView(dialogFilterView);
            }
            else if (typeDialog == Dialog.Duplicate)
            {
                await DuplicateFilterView(dialogFilterView);
            }
        }
        if (e.Key == "Escape") await AddFilterMudMenu.CloseMenuAsync();
    }

    /// <summary>
    /// Affiche ou non la popup de filtre
    /// </summary>
    /// <param name="propertyName">Vue de filtres à sélectionner</param>
    private void TogglePopover(string propertyName = null, bool cleanUnusedFilter = true)
    {
        if (openFilter == propertyName || propertyName == null)
        {
            openFilter = "";
            _open = false;
            if (cleanUnusedFilter)
                CleanUnusedFilters();
        }
        else
        {
            openFilter = propertyName;
            _open = true;
        }
    }

