    /// <summary>
    /// Duplique une vue de filtres
    /// </summary>
    /// <param name="filterView">Vue de filtre à dupliquer</param>
    public async Task DuplicateFilterView(FilterView<object> filterView)
    {
        if (!ValidateViewName()) return;
        CloseDialog();
        var dupeFilterView = new FilterView<object>
            {
                Name = viewName,
                Filters = filterView.Filters.ToList(),
                ColumnOrder = filterView.ColumnOrder,
                Columns = filterView.Columns,
                OriginalTypeName = filterView.OriginalTypeName
            };
        filterViews.Add(dupeFilterView);
        await SaveFilterView(dupeFilterView.Name);
