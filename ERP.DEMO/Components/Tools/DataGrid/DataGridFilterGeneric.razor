    private async Task enterKeyPressed(KeyboardEventArgs e, string name, IntRangeValue enumValue = IntRangeValue.Exact, bool intRange = false)
    {
        if (e.Key == "Enter")
        {
            enterKey = true;
            TogglePopover();
            var value = enumValue switch
            {
                IntRangeValue.Exact => new IntDictionnary { Exact = filterValuesInt[name].Exact },
                IntRangeValue.Min => new IntDictionnary { Min = filterValuesInt[name].Min, Max = filterValuesInt[name].Max },
                IntRangeValue.Max => new IntDictionnary { Min = filterValuesInt[name].Min, Max = filterValuesInt[name].Max },
                _ => throw new ArgumentOutOfRangeException()
            };
            await AddFilter(name, value, FilterDictionary.FilterValuesInt, intRange: intRange);
        }
    }

    #region JSONELEMENT
    private IntDictionnary GetIntDictionnaryFromJsonElement(JsonElement jsonElementObject)
    {
        if (jsonElementObject.TryGetProperty("Exact", out var exact) || jsonElementObject.TryGetProperty("Min", out var min) || jsonElementObject.TryGetProperty("Max", out var max))
        {
            var intDictionnary1 = new IntDictionnary();
            if (jsonElementObject.TryGetProperty("Exact", out exact))
            {
                intDictionnary1.Exact = (exact.ValueKind != JsonValueKind.Null ? (exact.TryGetInt32(out int r) ? r : null) : null);
            }
            if (jsonElementObject.TryGetProperty("Min", out min))
            {
                intDictionnary1.Min = (min.ValueKind != JsonValueKind.Null ? (min.TryGetInt32(out int r) ? r : null) : null);
            }
            if (jsonElementObject.TryGetProperty("Max", out max))
            {
                intDictionnary1.Max = (max.ValueKind != JsonValueKind.Null ? (max.TryGetInt32(out int r) ? r : null) : null);
            }
            return intDictionnary1;
        }
        return null;
    }

    private DateRange GetDateRangeFromJsonElement(JsonElement jsonElementObject)
    {
        if (jsonElementObject.TryGetProperty("Start", out var start) && jsonElementObject.TryGetProperty("End", out var end))
        {
            var dateRange = new MudBlazor.DateRange(start.GetDateTime(), end.GetDateTime());
            return dateRange;
        }
        return null;
    }

    private IEnumerable<string> GetArrayFromJsonElement(JsonElement jsonElementObject)
    {
        var valueArray = jsonElementObject.EnumerateArray().Select(e => e.GetString()).ToList();

        return valueArray;
    }
