<MudDialog Class="dialog" TitleClass="dialog-header" ActionsClass="dialog-footer">
    <TitleContent>Paramètres du tableau</TitleContent>
    <DialogContent>
        <div class="row mb-4">
            <MudText Typo="Typo.h6" Class="text-left mb-2">Paramètres d'affichage</MudText>
            <div class="d-flex gap-4">
                <MudCheckBox @bind-Value="dataGridParameters.Dense" Label="Affichage compact" Color="Color.Info" />
                <MudCheckBox @bind-Value="dataGridParameters.IsStripedRows" Label="Zébrage" Color="Color.Info" />
                <MudCheckBox @bind-Value="dataGridParameters.Hover" Label="Effet au survol" Color="Color.Info" />
                <MudCheckBox @bind-Value="dataGridParameters.ShowBorders" Label="Bordures" Color="Color.Info" />
            </div>
        </div>

        <div class="row mb-4">
            <MudText Typo="Typo.h6" Class="text-left mb-2">Paramètres de filtre</MudText>
            <MudCheckBox @bind-Value="dataGridParameters.SaveGlobalSearch" Label="Sauvegarder la recherche globale dans une vue" Color="Color.Info" />
        </div>

        <div class="d-flex justify-start mt-4">

            <MudButton Variant="Variant.Text"
                       StartIcon="@Icons.Material.Filled.RestartAlt"
                       OnClick="ResetToDefaults"
                       Color="Color.Warning">
                Réinitialiser aux paramètres globaux
            </MudButton>
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Outlined" Color="Color.Default">
            Annuler
        </MudButton>
        <MudButton OnClick="ApplyDisplaySettings" Variant="Variant.Filled" Color="Color.Info">
            Appliquer
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private MudDialogInstance MudDialog { get; set; }

    [Parameter]
    public DataGridParameters dataGridParameters { get; set; }

    private void Cancel() => MudDialog.Cancel();

    private void ResetToDefaults()
    {
        // Ici, on remet les valeurs par défaut définies dans la classe DataGridParameters
        // Plus tard, vous pourrez injecter ici votre service de préférences globales
        var defaults = new DataGridParameters();
        
        dataGridParameters.Dense = defaults.Dense;
        dataGridParameters.ShowBorders = defaults.ShowBorders;
        dataGridParameters.IsStripedRows = defaults.IsStripedRows;
        dataGridParameters.Hover = defaults.Hover;
        dataGridParameters.SaveGlobalSearch = defaults.SaveGlobalSearch;
    }

    private void ApplyDisplaySettings()
    {
        // On retourne l'objet complet mis à jour
        MudDialog.Close(DialogResult.Ok(dataGridParameters));
    }
}