@* @typeparam TModel

<MudDataGrid T="TModel"
             ServerData="@ViewModel.GetDataAsync"
             Class="rounded-lg boxShadow"
             Loading="@ViewModel.Loading"
             ReadOnly="false"
             EditMode="DataGridEditMode.Form"
             EditTrigger="DataGridEditTrigger.Manual"
             Virtualize="true"
             SortMode="SortMode.Single"
             FilterMode="DataGridFilterMode.Simple"
             Filterable="true"
             DragDropColumnReordering
             ColumnsPanelReordering
             FixedHeader
             Hover
             Striped
             ShowMenuIcon
             Groupable
             Hideable
             Dense
             @ref="dataGrid">
    <ToolBarContent>
        <MudText Typo="Typo.h6">@ViewModel.Title</MudText>
        <MudSpacer />
        <MudTextField T="string" ValueChanged="@(s => OnSearch(s))" Placeholder="Rechercher"
                      Adornment="Adornment.Start" Immediate="true"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      IconSize="MudBlazor.Size.Medium" Class="mt-0" Style="margin-right:20px"></MudTextField>
    </ToolBarContent>

    <Columns>
        @foreach (var column in ViewModel.Columns.Where(c => !c.Hidden))
        {
            if (column.CellTemplate != null)
            {
                <PropertyColumn Property="@column.Property" Title="@column.Title" Hidden="@column.HiddenDefault" DragAndDropEnabled="@column.Draggable" Filterable="@column.Filterable" >
                    <CellTemplate>
                        @column.CellTemplate(context.Item)
                    </CellTemplate>
                </PropertyColumn>
            }
            else
            {
                <PropertyColumn Property="@column.Property" Title="@column.Title" Hidden="@column.HiddenDefault" DragAndDropEnabled="@column.Draggable" Filterable="@column.Filterable" />
            }
        }
    </Columns>

    <PagerContent>
        <MudDataGridPager T="TModel" />
    </PagerContent>
</MudDataGrid>

@code {
    [Parameter, EditorRequired] 
    public DataGridViewModelGeneric<TModel> ViewModel { get; set; }
    private MudDataGrid<TModel> dataGrid;

    private void OnSearch(string searchTerm)
    {
        ViewModel.SearchTerm = searchTerm;
        dataGrid.ReloadServerData();
    }
} *@
