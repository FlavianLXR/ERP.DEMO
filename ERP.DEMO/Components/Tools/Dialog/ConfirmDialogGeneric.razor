@using MudBlazor
@inject IDialogService DialogService

<MudDialog Class="dialog" TitleClass="dialog-header" ContentClass="" ActionsClass="dialog-footer">
    <DialogContent>
        <MudText Typo="Typo.h6" Class="text-center mb-2">@ContentText</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => MudDialog.Cancel()" Variant="Variant.Outlined" Color="Color.Default" Class="me-2">Annuler</MudButton>
        <MudButton OnClick="() => MudDialog.Close(DialogResult.Ok(true))" Variant="Variant.Filled" Color="@Color">@ButtonText</MudButton>
    </DialogActions>
</MudDialog> 

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public string ContentText { get; set; } = "Confirmer ?";
    [Parameter] public string ButtonText { get; set; } = "Valider";
    [Parameter] public Color Color { get; set; } = Color.Primary;
}
